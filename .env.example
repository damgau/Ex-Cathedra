# Copy to .env and fill in real values. Never commit .env.

# Anthropic / Claude API
ANTHROPIC_API_KEY=

# Google OAuth (used with credentials.json / token.json)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Sheets / Drive (service account or OAuth)
GOOGLE_SHEET_ID=

# Optional: project-level identifiers
PROJECT_NAME=

# Optional: full path to ffmpeg/ffprobe if they're not on PATH.
# Leave blank — the tools auto-detect a winget install (Gyan.FFmpeg) otherwise.
FFMPEG_BIN=
FFPROBE_BIN=
